<Window x:Class="PL.Order.OrdersToPick"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Order"
        mc:Ignorable="d"
        Title="Available Orders" Height="600" Width="900"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F8FF" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock FontSize="18" FontWeight="Bold" Text="Available Orders for Pickup"/>
                    <TextBlock FontSize="12" Foreground="Gray" Margin="0,5,0,0" 
                               Text="{Binding CourierInfo}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="DarkBlue">
                        <Run Text="Max Distance: "/>
                        <Run Text="{Binding MaxDistanceDisplay}"/>
                    </TextBlock>
                </StackPanel>

            </Grid>
        </Border>

        <ListView Grid.Row="1" ItemsSource="{Binding OrderList}" 
                  SelectedItem="{Binding SelectedOrder}"
                  MouseDoubleClick="ListView_MouseDoubleClick" x:Name="lvOrders">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Order ID" DisplayMemberBinding="{Binding OrderId}" Width="80"/>
                    <GridViewColumn Header="Address" DisplayMemberBinding="{Binding FullAddress}" Width="300"/>
                    <GridViewColumn Header="Air Distance (km)" DisplayMemberBinding="{Binding AirDistanceDisplay}" Width="120"/>
                    <GridViewColumn Header="Order Type" DisplayMemberBinding="{Binding OrderType}" Width="100"/>
                    <GridViewColumn Header="Is Heavy" DisplayMemberBinding="{Binding IsHeavy}" Width="70"/>
                    <GridViewColumn Header="Time Remaining" DisplayMemberBinding="{Binding TimeRemainingDisplay}" Width="130"/>

                    <GridViewColumn Header="Schedule Status" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ScheduleStatus}" 
                                           Foreground="Black"
                                           FontWeight="Bold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="2" Background="#EEEEEE" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="Pick Order" Click="BtnPickOrder_Click" Width="180" Height="40" Margin="15" 
                        FontWeight="Bold" Background="#90EE90" IsEnabled="{Binding IsOrderSelected}"/>

                <Button Content="Refresh List" Click="BtnRefresh_Click" Width="150" Height="40" Margin="15" FontWeight="SemiBold"/>

                <Button Content="Close" Click="BtnClose_Click" Width="150" Height="40" Margin="15" Background="#FFB6C1" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>