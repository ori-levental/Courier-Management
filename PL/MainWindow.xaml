<local:NetworkAwareWindow x:Class="PL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL" 
        mc:Ignorable="d"
        Title="MainWindow - Delivery System Management" Height="760" Width="1000"
        WindowState="Maximized"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F8FF" BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Label Content="System Clock:" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    <Label Content="{Binding CurrentTime}" FontSize="18" Foreground="DarkBlue" 
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="+ Min" Click="BtnAddMinute_Click" Margin="3" Padding="10,5"/>
                    <Button Content="+ Hour" Click="BtnAddHour_Click" Margin="3" Padding="10,5"/>
                    <Button Content="+ Day" Click="BtnAddDay_Click" Margin="3" Padding="10,5"/>
                    <Button Content="+ Month" Click="BtnAddMonth_Click" Margin="3" Padding="10,5"/>
                    <Button Content="+ Year" Click="BtnAddYear_Click" Margin="3" Padding="10,5"/>
                </WrapPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Orders Status Summary" Margin="5" Padding="10" BorderBrush="DarkBlue" Background="#FAFAFA">
                    <UniformGrid Columns="5" Rows="1">
                        <StackPanel HorizontalAlignment="Center">
                            <Label Content="Open" FontWeight="Bold" Foreground="Green"/>
                            <TextBlock Text="{Binding OrderStatistics.OpenCount}" HorizontalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <Label Content="On Care" FontWeight="Bold" Foreground="Orange"/>
                            <TextBlock Text="{Binding OrderStatistics.OnCareCount}" HorizontalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <Label Content="Provided" FontWeight="Bold" Foreground="Gray"/>
                            <TextBlock Text="{Binding OrderStatistics.ProvidedCount}" HorizontalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <Label Content="Refused" FontWeight="Bold" Foreground="DarkRed"/>
                            <TextBlock Text="{Binding OrderStatistics.RefusedCount}" HorizontalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <Label Content="Cancelled" FontWeight="Bold" Foreground="Red"/>
                            <TextBlock Text="{Binding OrderStatistics.CancelledCount}" HorizontalAlignment="Center" FontSize="16"/>
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>

                <Label Grid.Row="1" Content="System Configuration" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15,0,15"/>

                <GroupBox Grid.Row="2" Header="Average Speeds (km/h)" Margin="5" Padding="10">
                    <UniformGrid Columns="4" Rows="1">
                        <StackPanel Margin="5">
                            <Label Content="Car Speed:"/>
                            <TextBox Text="{Binding Configuration.AvgCarSpeed, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Motorcycle Speed:"/>
                            <TextBox Text="{Binding Configuration.AvgMotorcycleSpeed, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Bicycle Speed:"/>
                            <TextBox Text="{Binding Configuration.AvgBicycleSpeed, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <Label Content="Walking Speed:"/>
                            <TextBox Text="{Binding Configuration.AvgWalkSpeed, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Grid.Row="3" Header="Location &amp; Distance Limits" Margin="5" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Margin="5"
                                 Text="{Binding Configuration.CompanyAddress, UpdateSourceTrigger=PropertyChanged}" Padding="3"
                                 
                                 BorderBrush="{Binding AddressBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                 BorderThickness="2"
                                 ToolTip="{Binding AddressStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                 
                                 ToolTipService.InitialShowDelay="0"
                                 ToolTipService.ShowDuration="20000">

                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="ToolTip" Value="{x:Null}">
                                            <Setter Property="ToolTipService.IsEnabled" Value="False"/>
                                        </Trigger>
                                        <Trigger Property="ToolTipService.IsEnabled" Value="True">
                                            <Setter Property="Background" Value="#FFF8F8"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <StackPanel Grid.Column="3" Margin="5">
                            <Label Content="Max Air Distance (km):"/>
                            <TextBox Text="{Binding Configuration.MaxRange, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="4" Header="Time Constraints" Margin="5" Padding="10">
                    <UniformGrid Columns="3" Rows="1">
                        <StackPanel Margin="5">
                            <Label Content="Max Delivery Time:"/>
                            <TextBox Padding="3" ToolTip="Format: Hours:Minutes:Seconds">
                                <TextBox.Text>
                                    <Binding Path="Configuration.MaxDeliveryTime" 
                                             UpdateSourceTrigger="PropertyChanged" 
                                             Mode="TwoWay"
                                             StringFormat="{}{0:hh\:mm\:ss}"/>
                                </TextBox.Text>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Risk Range:"/>
                            <TextBox Padding="3" ToolTip="Format: Hours:Minutes:Seconds">
                                <TextBox.Text>
                                    <Binding Path="Configuration.RiskRange" 
                                             UpdateSourceTrigger="PropertyChanged" 
                                             Mode="TwoWay"
                                             StringFormat="{}{0:hh\:mm\:ss}"/>
                                </TextBox.Text>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Margin="5">
                            <Label Content="Inactivity Timeout:"/>
                            <TextBox Padding="3" ToolTip="Format: Days.Hours:Minutes:Seconds">
                                <TextBox.Text>
                                    <Binding Path="Configuration.CourierInactivityTime" 
                                             UpdateSourceTrigger="PropertyChanged" 
                                             Mode="TwoWay"
                                             StringFormat="{}{0:dd\.hh\:mm\:ss}"/>
                                </TextBox.Text>
                            </TextBox>
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Grid.Row="5" Header="Manager Credentials" Margin="5" Padding="10" BorderBrush="Purple">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="5">
                            <Label Content="Manager ID:"/>
                            <TextBox Text="{Binding Configuration.ManagerId, UpdateSourceTrigger=PropertyChanged}" Padding="3"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5">
                            <Label Content="Manager Password:"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="pbManagerPass" PasswordChar="●" 
                                             PasswordChanged="PbManagerPass_PasswordChanged"
                                             Padding="3" Height="24" VerticalContentAlignment="Center"/>

                                <TextBox x:Name="txtVisibleManagerPass" 
                                         Text="{Binding Configuration.ManagerPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="3" Height="24" VerticalContentAlignment="Center" Visibility="Collapsed"/>

                                <Button Grid.Column="1" Content="👁" Width="30" Height="24" Margin="2,0,0,0"
                                        Background="Transparent" BorderThickness="0"
                                        Click="BtnToggleManagerPass_Click" ToolTip="Show/Hide Password"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <Button Grid.Row="6" Content="Update Configuration" Click="BtnSaveConfig_Click" 
                        HorizontalAlignment="Center" Width="200" Height="35" Margin="0,20,0,0" FontWeight="Bold"/>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#EEEEEE" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Initialize DB" Click="BtnInitDB_Click" Width="130" Height="40" Margin="15" Background="#90EE90" FontWeight="SemiBold"/>

                <Button Content="Reset DB" Click="BtnResetDB_Click" Width="130" Height="40" Margin="15" Background="#FFB6C1" FontWeight="SemiBold"/>

                <Button Content="Manage Couriers" Click="BtnShowList_Click" 
                        Width="180" Height="40" Margin="50,15,15,15" FontWeight="Bold" BorderThickness="2" HorizontalAlignment="Center" Background="#FFBEC6FF"/>

                <Button Content="Manage Orders" Click="BtnShowOrderList_Click" Width="180" Height="40" Margin="15" FontWeight="Bold" BorderThickness="2" HorizontalAlignment="Center" Background="#FFE4B5"/>
            </StackPanel>
        </Border>

    </Grid>
</local:NetworkAwareWindow>