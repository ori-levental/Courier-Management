<Window x:Class="PL.Delivery.DeliveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Delivery"
        mc:Ignorable="d"
        Title="Delivery Details" Height="600" Width="700"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">

    <Window.Resources>
        <!-- Converters removed - using static properties from code-behind instead -->

        <!-- Label style: right aligned, consistent margin -->
        <Style x:Key="RightLabelStyle" TargetType="Label">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Common style for input controls: consistent margin and min width -->
        <Style x:Key="ValueControlStyle" TargetType="Control">
            <Setter Property="Margin" Value="6,4,12,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="200"/>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource ValueControlStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource ValueControlStyle}"/>
        <Style TargetType="DatePicker" BasedOn="{StaticResource ValueControlStyle}"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource ValueControlStyle}"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="160"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 0: Delivery ID - visible and readonly -->
        <TextBox Grid.Row="0" Grid.Column="0"
                 Text="{Binding CurrentDelivery.DeliveryId, Mode=TwoWay, NotifyOnValidationError=True, ValidatesOnExceptions=True}"
                 IsReadOnly="True"
                 ToolTip="Unique Delivery Identifier"/>
        <Label Grid.Row="0" Grid.Column="1" Style="{StaticResource RightLabelStyle}" Content="Delivery ID"/>

        <!-- 1: Full Name -->
        <TextBox Grid.Row="1" Grid.Column="0"
                 Text="{Binding CurrentDelivery.FullName, Mode=TwoWay, NotifyOnValidationError=True, ValidatesOnExceptions=True}"
                 ToolTip="Full Name of Delivery Person"/>
        <Label Grid.Row="1" Grid.Column="1" Style="{StaticResource RightLabelStyle}" Content="Full Name"/>

        <!-- 2: Delivery Type (Shipping Type) -->
        <ComboBox Grid.Row="2" Grid.Column="0"
                  ItemsSource="{Binding DeliveryTypes}"
                  SelectedItem="{Binding CurrentDelivery.ShippingType, Mode=TwoWay}"
                  IsSynchronizedWithCurrentItem="False"
                  ToolTip="Type of Vehicle/Shipping Method"/>
        <Label Grid.Row="2" Grid.Column="1" Style="{StaticResource RightLabelStyle}" Content="Delivery Type"/>

        <!-- 3: Employment Start Date -->
        <DatePicker Grid.Row="3" Grid.Column="0"
                    SelectedDate="{Binding CurrentDelivery.EmploymentStartDate, Mode=TwoWay, NotifyOnValidationError=True, ValidatesOnExceptions=True}"
                    ToolTip="Employment Start Date"/>
        <Label Grid.Row="3" Grid.Column="1" Style="{StaticResource RightLabelStyle}" Content="Employment Date"/>

        <!-- 4: Is Active Status -->
        <CheckBox Grid.Row="4" Grid.Column="0"
                  IsChecked="{Binding CurrentDelivery.IsActive, Mode=TwoWay, NotifyOnValidationError=True, ValidatesOnExceptions=True}"
                  ToolTip="Is This Delivery Person Active?"/>
        <Label Grid.Row="4" Grid.Column="1" Style="{StaticResource RightLabelStyle}" Content="Is Active"/>

        <!-- 5: Sum Order In Time (Read-Only) -->
        <TextBox Grid.Row="5" Grid.Column="0"
                 Text="{Binding CurrentDelivery.SumOrderInTime, Mode=OneWay}"
                 IsReadOnly="True"
                 ToolTip="Total Orders Delivered On Time"/>
        <Label Grid.Row="5" Grid.Column="1" Style="{StaticResource RightLabelStyle}" Content="Orders In Time"/>

        <!-- 6: Sum Order In Late (Read-Only) -->
        <TextBox Grid.Row="6" Grid.Column="0"
                 Text="{Binding CurrentDelivery.SumOrderInLate, Mode=OneWay}"
                 IsReadOnly="True"
                 ToolTip="Total Orders Delivered Late"/>
        <Label Grid.Row="6" Grid.Column="1" Style="{StaticResource RightLabelStyle}" Content="Orders Late"/>

        <!-- 7: Order In Care (Read-Only) -->
        <TextBox Grid.Row="7" Grid.Column="0"
                 Text="{Binding CurrentDelivery.IdOrderInCare, Mode=OneWay}"
                 IsReadOnly="True"
                 ToolTip="Current Order Being Handled (null if idle)"/>
        <Label Grid.Row="7" Grid.Column="1" Style="{StaticResource RightLabelStyle}" Content="Order In Care"/>

        <!-- Action Button centered in the bottom row -->
        <Button Grid.Row="8" Grid.Column="0"
                Content="{Binding ButtonText}"
                Click="btnAddUpdate_Click"
                HorizontalAlignment="Center"
                Margin="0,40,0,40"
                Width="140"
                Height="40"/>
    </Grid>
</Window>