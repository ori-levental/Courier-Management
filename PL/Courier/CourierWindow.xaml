<Window x:Class="PL.Courier.CourierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Courier"
        xmlns:bo="clr-namespace:BO;assembly=BL" 
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Courier Details" Height="550" Width="800"
        WindowState="Maximized"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">

    <Window.Resources>
        <ObjectDataProvider x:Key="ShippingTypeEnum" 
                            MethodName="GetValues" 
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="bo:ShippingType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="OrderDetailsVisibilityStyle" TargetType="GroupBox">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentCourier.OrderInCare}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,10,5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="25"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Column="0" Header="Courier Personal Details" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="ID:" Grid.Row="0" Grid.Column="0"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         Text="{Binding CurrentCourier.Id, Mode=TwoWay}"
                         IsEnabled="{Binding IsAddMode}"/>

                <Label Content="Full Name:" Grid.Row="1" Grid.Column="0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CurrentCourier.FullName, Mode=TwoWay}"/>

                <Label Content="Phone:" Grid.Row="2" Grid.Column="0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CurrentCourier.PhoneNumber, Mode=TwoWay}"/>

                <Label Content="Email:" Grid.Row="3" Grid.Column="0"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CurrentCourier.Email, Mode=TwoWay}"/>

                <Label Content="Password:" Grid.Row="4" Grid.Column="0"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CurrentCourier.Password, Mode=TwoWay}"/>

                <Label Content="Max Distance (km):" Grid.Row="5" Grid.Column="0"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CurrentCourier.DistanceToDelivery, Mode=TwoWay}"/>

                <Label Content="Delivery Type:" Grid.Row="6" Grid.Column="0"/>
                <ComboBox Grid.Row="6" Grid.Column="1" 
                          ItemsSource="{Binding Source={StaticResource ShippingTypeEnum}}"
                          SelectedItem="{Binding CurrentCourier.DeliveryType, Mode=TwoWay}"
                          Height="25" Margin="0,5"/>

                <Label Content="Is Active:" Grid.Row="7" Grid.Column="0"/>
                <CheckBox Grid.Row="7" Grid.Column="1" 
                          IsChecked="{Binding CurrentCourier.IsActive, Mode=TwoWay}"
                          VerticalAlignment="Center" Margin="0,5"/>

                <Label Content="Start Date:" Grid.Row="8" Grid.Column="0"/>
                <TextBlock Grid.Row="8" Grid.Column="1" 
                           Text="{Binding CurrentCourier.EmploymentStartDate, StringFormat='dd/MM/yyyy'}"
                           VerticalAlignment="Center" Foreground="Gray"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Column="2" Margin="10,0,0,0">

            <GroupBox Header="Performance Statistics" Height="100" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="On Time" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentCourier.SumOrderInTime}" 
                                   Foreground="Green" FontSize="20" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Late" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentCourier.SumOrderInLate}" 
                                   Foreground="Red" FontSize="20" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="Current Order In Care" 
                      Style="{StaticResource OrderDetailsVisibilityStyle}"
                      BorderBrush="Blue">

                <Grid DataContext="{Binding CurrentCourier.OrderInCare}" Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="Margin" Value="0,3"/>
                        </Style>
                        <Style TargetType="Label">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="0,3,5,3"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </Grid.Resources>

                    <Label Content="Order ID:" Grid.Row="0"/>
                    <TextBlock Text="{Binding OrderId}" Grid.Row="0" Grid.Column="1"/>

                    <Label Content="Customer:" Grid.Row="1"/>
                    <TextBlock Text="{Binding CustomerName}" Grid.Row="1" Grid.Column="1"/>

                    <Label Content="Address:" Grid.Row="2"/>
                    <TextBlock Text="{Binding Address}" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap"/>

                    <Label Content="Status:" Grid.Row="3"/>
                    <TextBlock Text="{Binding ScheduleStatus}" Grid.Row="3" Grid.Column="1"/>

                    <Label Content="Distance:" Grid.Row="4"/>
                    <TextBlock Text="{Binding AirDistance, StringFormat='{}{0:F2} km'}" Grid.Row="4" Grid.Column="1"/>

                    <Label Content="ETA:" Grid.Row="5"/>
                    <TextBlock Text="{Binding EstimatedArrivalTime, StringFormat='HH:mm'}" Grid.Row="5" Grid.Column="1"/>

                    <Label Content="Time Left:" Grid.Row="6"/>
                    <TextBlock Text="{Binding TimeLeft, StringFormat={}{0:hh\\:mm}}" Grid.Row="6" Grid.Column="1" FontWeight="Bold"/>
                    <Label Content="Note:" Grid.Row="7"/>
                    <TextBlock Text="{Binding Description}" Grid.Row="7" Grid.Column="1" FontStyle="Italic" TextWrapping="Wrap"/>
                </Grid>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">

            <Button Content="{Binding ButtonContent}" 
                    Click="BtnAction_Click"
                    FontWeight="Bold" FontSize="16" Height="40" Width="200" Margin="10"/>

            <Button Content="Delete Courier" 
                    Click="BtnDelete_Click"
                    Background="#FF4444" Foreground="White"
                    FontWeight="Bold" FontSize="16" Height="40" Width="150" Margin="10">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>

                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsAddMode}" Value="False"/>

                                    <Condition Binding="{Binding CurrentCourier.OrderInCare}" Value="{x:Null}"/>

                                    <Condition Binding="{Binding CurrentCourier.SumOrderInTime}" Value="0"/>

                                    <Condition Binding="{Binding CurrentCourier.SumOrderInLate}" Value="0"/>
                                </MultiDataTrigger.Conditions>

                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

    </Grid>
</Window>