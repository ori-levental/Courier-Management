<Window x:Class="PL.Courier.OrdersHistory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PL.Courier"
        Title="Order History" Height="600" Width="1000"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Background="#2196F3" Margin="0">
            <StackPanel.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Margin" Value="0,0,0,10"/>
                </Style>
            </StackPanel.Resources>
            <Border Padding="20" Background="Transparent">
                <StackPanel>
                    <TextBlock Text="{Binding CourierInfo}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Closed Orders History" FontSize="14" Foreground="#E3F2FD" Margin="0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Filter Section -->
        <Border Grid.Row="1" Background="White" Padding="20" BorderBrush="#CCCCCC" BorderThickness="0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- DeliveryEndType Filter -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Filter by Completion Status:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Name="CmbEndType"
                              SelectedValuePath="Content"
                              SelectedValue="{Binding SelectedEndType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Padding="10"
                              Foreground="#333">
                        <ComboBoxItem>All</ComboBoxItem>
                        <ComboBoxItem>Provided</ComboBoxItem>
                        <ComboBoxItem>Cancelled</ComboBoxItem>
                        <ComboBoxItem>Refused</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- OrderType Filter -->
                <StackPanel Grid.Column="1" Margin="0,0,20,0">
                    <TextBlock Text="Filter by Order Type:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Name="CmbOrderType"
                              SelectedValuePath="Content"
                              SelectedValue="{Binding SelectedOrderType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Padding="10"
                              Foreground="#333">
                        <ComboBoxItem>All</ComboBoxItem>
                        <ComboBoxItem>Express</ComboBoxItem>
                        <ComboBoxItem>Standard</ComboBoxItem>
                        <ComboBoxItem>Scheduled</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Button Click="BtnClearFilters_Click" Padding="15,10" Margin="0,0,10,0" 
                            Background="#FF9800" Foreground="White" FontWeight="SemiBold"
                            Content="Clear Filters"/>
                    <Button Click="BtnRefresh_Click" Padding="15,10" Margin="0,0,10,0" 
                            Background="#4CAF50" Foreground="White" FontWeight="SemiBold"
                            Content="Refresh"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Orders List -->
        <ListView Grid.Row="2" ItemsSource="{Binding ClosedOrdersList}" 
                  Background="White" Margin="0,1,0,0"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListView.View>
                <GridView AllowsColumnReorder="True">
                    <GridViewColumn Header="Delivery ID" Width="100" DisplayMemberBinding="{Binding DeliveryId}"/>
                    <GridViewColumn Header="Order ID" Width="100" DisplayMemberBinding="{Binding OrderId}"/>
                    <GridViewColumn Header="Address" Width="250" DisplayMemberBinding="{Binding FullAddress}"/>
                    <GridViewColumn Header="Order Type" Width="120" DisplayMemberBinding="{Binding OrderType}"/>
                    <GridViewColumn Header="Status" Width="120" DisplayMemberBinding="{Binding DeliveryEndTypeDisplay}"/>
                    <GridViewColumn Header="Completion Date" Width="180" DisplayMemberBinding="{Binding DeliveryEndTimeDisplay}"/>
                    <GridViewColumn Header="Distance (km)" Width="120" DisplayMemberBinding="{Binding ActualDistanceDisplay}"/>
                    <GridViewColumn Header="Processing Time" Width="140" DisplayMemberBinding="{Binding TotalProcessingTimeDisplay}"/>
                    <GridViewColumn Header="Shipping Type" Width="120" DisplayMemberBinding="{Binding ShippingType}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Statistics Section -->
        <Border Grid.Row="3" Background="#F9F9F9" Padding="20" BorderBrush="#CCCCCC" BorderThickness="0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Deliveries -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <TextBlock Text="Total Deliveries" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalDeliveries}" FontSize="28" FontWeight="Bold" Foreground="#2196F3"/>
                </StackPanel>

                <!-- Successful Deliveries -->
                <StackPanel Grid.Column="1" Margin="0,0,20,0">
                    <TextBlock Text="Successful" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding SuccessfulDeliveries}" FontSize="28" FontWeight="Bold" Foreground="#4CAF50"/>
                </StackPanel>

                <!-- Cancelled Deliveries -->
                <StackPanel Grid.Column="2" Margin="0,0,20,0">
                    <TextBlock Text="Cancelled" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CancelledDeliveries}" FontSize="28" FontWeight="Bold" Foreground="#F44336"/>
                </StackPanel>

                <!-- Average Processing Time -->
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Avg Processing Time" FontWeight="SemiBold" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding AverageProcessingTime}" FontSize="24" FontWeight="Bold" Foreground="#FF9800"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer Section with Close Button -->
        <Border Grid.Row="4" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,0,0">
                <Button Click="BtnClose_Click" Padding="20,10" 
                        Background="#757575" Foreground="White" FontWeight="SemiBold"
                        Content="Close" Width="100"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
