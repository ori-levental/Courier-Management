<Window x:Class="PL.Courier.MainCourierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Courier"
        xmlns:bo="clr-namespace:BO;assembly=BL"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Courier Dashboard" Height="680" Width="500"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">

    <Window.Resources>
        <ObjectDataProvider x:Key="ShippingTypeEnum" 
                            MethodName="GetValues" 
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="bo:ShippingType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,3,5,3"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Personal Details" BorderBrush="Gray" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Content="ID:" Grid.Row="0"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Courier.Id, Mode=OneWay}" 
                         IsEnabled="False" Background="#F0F0F0"/>

                <Label Content="Name:" Grid.Row="1"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Courier.FullName}"/>

                <Label Content="Phone:" Grid.Row="2"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Courier.PhoneNumber}"/>

                <Label Content="Email:" Grid.Row="3"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Courier.Email}"/>

                <Label Content="Password:" Grid.Row="4"/>
                <Grid Grid.Row="4" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="pbPassword" Grid.Column="0" PasswordChar="●" 
                                 PasswordChanged="PbPassword_PasswordChanged"/>

                    <TextBox x:Name="txtVisiblePassword" Grid.Column="0" 
                             Text="{Binding Courier.Password, Mode=TwoWay}" 
                             Visibility="Collapsed"/>

                    <Button Grid.Column="1" Content="👁" Width="30" Height="24" Margin="2,0,0,0"
                            Background="Transparent" BorderThickness="0"
                            Click="BtnTogglePassword_Click" ToolTip="Show/Hide Password"/>
                </Grid>

                <Label Content="Start Date:" Grid.Row="5"/>
                <TextBox Grid.Row="5" Grid.Column="1" 
                         Text="{Binding Courier.EmploymentStartDate, StringFormat='dd/MM/yyyy'}" 
                         IsEnabled="False" Background="#F0F0F0"/>

                <Label Content="Max Dist (km):" Grid.Row="6"/>
                <TextBox Grid.Row="6" Grid.Column="1" 
                         Text="{Binding Courier.DistanceToDelivery, TargetNullValue=''}"
                         ToolTip="Leave empty for no limit"/>

                <Label Content="Vehicle:" Grid.Row="7"/>
                <ComboBox Grid.Row="7" Grid.Column="1" 
                          ItemsSource="{Binding Source={StaticResource ShippingTypeEnum}}"
                          SelectedItem="{Binding Courier.DeliveryType}"
                          IsEnabled="{Binding IsVehicleEditable}"/>

                <Button Content="Update Details" Grid.Row="8" Grid.ColumnSpan="2" 
                        Click="BtnUpdate_Click" Background="#ADD8E6" Margin="0,15,0,0" Height="35"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Active Order Details" Margin="0,15,0,0"
                  Visibility="{Binding HasActiveOrder, Converter={StaticResource BoolToVis}}"
                  BorderBrush="#FFB347" BorderThickness="1">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,5" Orientation="Horizontal">
                            <TextBlock Text="Order #" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="{Binding Courier.OrderInCare.OrderId, Mode=OneWay}" FontWeight="Bold" FontSize="14" Margin="5,0,0,0"/>
                            <TextBlock Text=" | " Margin="5,0"/>

                            <TextBlock Text="{Binding Courier.OrderInCare.ScheduleStatus, Mode=OneWay}" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Blue"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Courier.OrderInCare.ScheduleStatus}" Value="OnTime">
                                                <Setter Property="Foreground" Value="Green"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Courier.OrderInCare.ScheduleStatus}" Value="InRisk">
                                                <Setter Property="Foreground" Value="OrangeRed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Courier.OrderInCare.ScheduleStatus}" Value="Late">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Label Content="Customer:" Grid.Row="1" Grid.Column="0" Padding="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                            <Run Text="{Binding Courier.OrderInCare.CustomerName, Mode=OneWay}"/>
                            <Run Text=" ("/><Run Text="{Binding Courier.OrderInCare.CustomerPhone, Mode=OneWay}"/><Run Text=")"/>
                        </TextBlock>

                        <Label Content="Address:" Grid.Row="2" Grid.Column="0" Padding="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Courier.OrderInCare.Address, Mode=OneWay}" 
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>

                        <Label Content="Trip Info:" Grid.Row="3" Grid.Column="0" Padding="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" VerticalAlignment="Center">
                            <Run Text="Dist: "/><Run Text="{Binding Courier.OrderInCare.Distance, StringFormat={}{0:F1} km, Mode=OneWay}"/>
                            <Run Text="  | ETA: "/><Run Text="{Binding Courier.OrderInCare.EstimatedArrivalTime, StringFormat='HH:mm', Mode=OneWay}"/>
                        </TextBlock>

                        <Label Content="Note:" Grid.Row="4" Grid.Column="0" Padding="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Courier.OrderInCare.Description, Mode=OneWay}" 
                                   VerticalAlignment="Center" FontStyle="Italic" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>

                <Label Grid.Row="1" Grid.Column="0" Content="Action:" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <Button Grid.Row="1" Grid.Column="1" Content="Delivery Provided" 
                        Click="BtnFinishOrder_Click" Background="#90EE90" Width="140"/>
            </Grid>
        </GroupBox>

        <Border Grid.Row="1" Margin="0,15,0,0" Padding="15" Background="#FAFAFA" BorderBrush="LightGray" BorderThickness="1"
                Visibility="{Binding HasNoActiveOrder, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="No active order at the moment." 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Foreground="Gray" FontStyle="Italic"/>
        </Border>

        <UniformGrid Grid.Row="3" Rows="1" Columns="2" Margin="0,20,0,0">
            <Button Content="View History" Click="BtnHistory_Click" Background="#DDDDDD" Height="40"/>
            <Button Content="Pick New Order" Click="BtnPickOrder_Click" 
                    IsEnabled="{Binding HasNoActiveOrder}" Background="#FFB6C1" Height="40"/>
        </UniformGrid>

    </Grid>
</Window>